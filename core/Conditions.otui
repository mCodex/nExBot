UturaComboBoxPopupMenu < NxComboBoxPopupMenu
UturaComboBoxPopupMenuButton < NxComboBoxPopupMenuButton
UturaComboBox < NxComboBox
  @onSetup: |
    self:addOption("Utura")
    self:addOption("Utura Gran")

CureConditions < NxPanel
  id: Cure
  padding: 3
  size: 200 230

  NxHeading
    id: cureHeading
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 6
    margin-left: 5
    text: Cure Conditions

  NxConditionRow
    id: poison
    anchors.top: cureHeading.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    @onSetup: self.name:setText("Poison")

  NxConditionRow
    id: curse
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    @onSetup: self.name:setText("Curse")

  NxConditionRow
    id: bleed
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    @onSetup: self.name:setText("Bleed")

  NxConditionRow
    id: burn
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    @onSetup: self.name:setText("Burn")

  NxConditionRow
    id: electrify
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    @onSetup: self.name:setText("Electrify")

  NxConditionRow
    id: paralyse
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    @onSetup: self.name:setText("Paralyse")

  NxConditionSpellRow
    id: paralyseSpell
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    @onSetup: self.name:setText("Spell:")

HoldConditions < NxPanel
  id: Hold
  padding: 3
  size: 200 250

  NxHeading
    id: holdHeading
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 6
    margin-left: 5
    text: Hold Conditions

  NxConditionRow
    id: haste
    anchors.top: holdHeading.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    @onSetup: self.name:setText("Haste")

  NxConditionSpellRow
    id: hasteSpell
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    @onSetup: self.name:setText("Spell:")

  NxConditionRow
    id: utana
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    @onSetup: self.name:setText("Utana Vid")

  NxConditionRow
    id: utamo
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    @onSetup: self.name:setText("Utamo Vita")

  NxConditionRow
    id: utura
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    @onSetup: self.name:setText("Recovery")

  NxLabel
    id: uturaSpellLabel
    anchors.left: parent.left
    anchors.top: prev.bottom
    margin-top: 10
    margin-left: 17
    text: Spell:
    font: verdana-11px-rounded

  UturaComboBox
    id: UturaType
    anchors.verticalCenter: uturaSpellLabel.verticalCenter
    anchors.left: uturaSpellLabel.right
    margin-left: 10
    width: 100

  NxCheckBox
    id: IgnoreInPz
    anchors.left: parent.left
    anchors.top: uturaSpellLabel.bottom
    margin-top: 12
    margin-left: 5
    font: verdana-11px-rounded

  NxLabel
    anchors.verticalCenter: IgnoreInPz.verticalCenter
    anchors.left: IgnoreInPz.right
    margin-top: 3
    margin-left: 5
    text: Don't Cast in Protection Zones
    font: cipsoftFont

  NxCheckBox
    id: StopHaste
    anchors.horizontalCenter: IgnoreInPz.horizontalCenter
    anchors.top: IgnoreInPz.bottom
    margin-top: 8

  NxLabel
    anchors.verticalCenter: StopHaste.verticalCenter
    anchors.left: StopHaste.right
    margin-top: 3
    margin-left: 5
    text: Stop Haste if TargetBot Is Active
    font: cipsoftFont

ConditionsWindow < NxWindow
  !text: tr('Condition Manager')
  size: 445 280
  @onEscape: self:hide()

  CureConditions
    id: Cure
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 7

  HoldConditions
    id: Hold
    anchors.top: parent.top
    anchors.right: parent.right
    margin-top: 7

  NxSeparator
    id: separator
    anchors.right: parent.right
    anchors.left: parent.left
    anchors.bottom: closeButton.top
    margin-bottom: 8

  NxButtonSm
    id: closeButton
    !text: tr('Close')
    anchors.right: parent.right
    anchors.bottom: parent.bottom
