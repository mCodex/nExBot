SpellSourceBoxPopupMenu < NxComboBoxPopupMenu
SpellSourceBoxPopupMenuButton < NxComboBoxPopupMenuButton
SpellSourceBox < NxComboBox
  @onSetup: |
    self:addOption("Current Mana")
    self:addOption("Current Health")
    self:addOption("Mana Percent")
    self:addOption("Health Percent")
    self:addOption("Burst Damage")

SpellConditionBoxPopupMenu < NxComboBoxPopupMenu
SpellConditionBoxPopupMenuButton < NxComboBoxPopupMenuButton
SpellConditionBox < NxComboBox
  @onSetup: |
    self:addOption("Below")
    self:addOption("Above")
    self:addOption("Equal To")

SpellEntry < NxListEntryCheckable

ItemEntry < NxListEntryCheckable

SpellHealing < NxPanel
  size: 490 130

  NxLabel
    id: title
    anchors.verticalCenter: parent.top
    anchors.left: parent.left
    margin-left: 5
    text: Spell Healing
    color: #46e6a6

  SpellSourceBox
    id: spellSource
    anchors.top: spellList.top
    anchors.left: spellList.right
    margin-left: 80
    width: 125
    font: verdana-11px-rounded

  NxLabel
    id: whenSpell
    anchors.left: spellList.right
    anchors.verticalCenter: prev.verticalCenter
    text: When
    margin-left: 7

  NxLabel
    id: isSpell
    anchors.left: spellList.right
    anchors.top: whenSpell.bottom
    text: Is
    margin-top: 9
    margin-left: 7

  SpellConditionBox
    id: spellCondition
    anchors.left: spellSource.left
    anchors.top: spellSource.bottom
    margin-top: 15
    width: 80
    font: verdana-11px-rounded

  NxTextInput
    id: spellValue
    anchors.left: spellCondition.right
    anchors.top: spellCondition.top
    anchors.bottom: spellCondition.bottom
    anchors.right: spellSource.right

  NxLabel
    id: castSpell
    anchors.left: isSpell.left
    anchors.top: isSpell.bottom
    text: Cast
    margin-top: 9

  NxTextInput
    id: spellFormula
    anchors.left: spellCondition.left
    anchors.top: spellCondition.bottom
    anchors.right: spellValue.right

  NxLabel
    id: manaSpell
    anchors.left: castSpell.left
    anchors.top: castSpell.bottom
    text: Mana Cost:
    margin-top: 8

  NxTextInput
    id: manaCost
    anchors.left: spellFormula.left
    anchors.top: spellFormula.bottom
    width: 40

  TextList
    id: spellList
    anchors.left: parent.left
    anchors.bottom: parent.bottom
    anchors.top: parent.top
    padding: 1
    padding-top: 2
    width: 270
    margin-bottom: 7
    margin-left: 7
    margin-top: 10
    vertical-scrollbar: spellListScrollBar

  VerticalScrollBar
    id: spellListScrollBar
    anchors.top: spellList.top
    anchors.bottom: spellList.bottom
    anchors.right: spellList.right
    step: 14
    pixels-scroll: true

  NxButton
    id: addSpell
    anchors.right: spellFormula.right
    anchors.bottom: spellList.bottom
    text: Add
    size: 40 17
    font: cipsoftFont

  NxButton
    id: MoveUp
    anchors.right: prev.left
    anchors.bottom: prev.bottom
    margin-right: 5
    text: Move Up
    size: 55 17
    font: cipsoftFont

  NxButton
    id: MoveDown
    anchors.right: prev.left
    anchors.bottom: prev.bottom
    margin-right: 5
    text: Move Down
    size: 55 17
    font: cipsoftFont

ItemHealing < NxPanel
  size: 490 120

  NxLabel
    id: title
    anchors.verticalCenter: parent.top
    anchors.left: parent.left
    margin-left: 5
    text: Item Healing
    color: #ff4b81

  SpellSourceBox
    id: itemSource
    anchors.top: itemList.top
    anchors.right: parent.right
    margin-right: 10
    width: 128
    font: verdana-11px-rounded

  NxLabel
    id: whenItem
    anchors.left: itemList.right
    anchors.verticalCenter: prev.verticalCenter
    text: When
    margin-left: 7

  NxLabel
    id: isItem
    anchors.left: itemList.right
    anchors.top: whenItem.bottom
    text: Is
    margin-top: 9
    margin-left: 7

  SpellConditionBox
    id: itemCondition
    anchors.left: itemSource.left
    anchors.top: itemSource.bottom
    margin-top: 15
    width: 80
    font: verdana-11px-rounded

  NxTextInput
    id: itemValue
    anchors.left: itemCondition.right
    anchors.top: itemCondition.top
    anchors.bottom: itemCondition.bottom
    width: 49

  NxLabel
    id: useItem
    anchors.left: isItem.left
    anchors.top: isItem.bottom
    text: Use
    margin-top: 15

  NxItem
    id: itemId
    anchors.left: itemCondition.left
    anchors.top: itemCondition.bottom

  TextList
    id: itemList
    anchors.left: parent.left
    anchors.bottom: parent.bottom
    anchors.top: parent.top
    padding: 1
    padding-top: 2
    width: 270
    margin-top: 10
    margin-bottom: 7
    margin-left: 8
    vertical-scrollbar: itemListScrollBar

  VerticalScrollBar
    id: itemListScrollBar
    anchors.top: itemList.top
    anchors.bottom: itemList.bottom
    anchors.right: itemList.right
    step: 14
    pixels-scroll: true

  NxButton
    id: addItem
    anchors.right: itemValue.right
    anchors.bottom: itemList.bottom
    text: Add
    size: 40 17
    font: cipsoftFont

  NxButton
    id: MoveUp
    anchors.right: prev.left
    anchors.bottom: prev.bottom
    margin-right: 5
    text: Move Up
    size: 55 17
    font: cipsoftFont

  NxButton
    id: MoveDown
    anchors.right: prev.left
    anchors.bottom: prev.bottom
    margin-right: 5
    text: Move Down
    size: 55 17
    font: cipsoftFont

HealerPanel < Panel
  size: 510 275

  SpellHealing
    id: spells
    anchors.top: parent.top
    margin-top: 8
    anchors.left: parent.left

  ItemHealing
    id: items
    anchors.top: prev.bottom
    anchors.left: parent.left
    margin-top: 10

HealBotSettingsPanel < Panel
  size: 500 267
  padding-top: 8

  Panel
    id: list
    anchors.left: parent.left
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    margin-right: 240
    padding-left: 6
    padding-right: 6
    padding-top: 6
    layout:
      type: verticalBox

    NxLabel
      id: sectionTitle
      text: Additional Settings
      color: #3be4d0
      font: verdana-11px-rounded
      height: 16
      text-align: left
      margin-bottom: 4

    HorizontalSeparator
      margin-bottom: 8

    NxCheckBox
      id: Cooldown
      text: Check spell cooldowns
      margin-top: 10

    NxCheckBox
      id: Visible
      text: Items must be visible (recommended)

    NxCheckBox
      id: Delay
      text: Don't use items when interacting

    NxCheckBox
      id: Interval
      text: Additional delay when looting corpses

    NxCheckBox
      id: Conditions
      text: Also check conditions from RL Tibia

    NxCheckBox
      id: MessageDelay
      text: Cooldown based on "Aaaah..." message

  VerticalSeparator
    anchors.top: prev.top
    anchors.bottom: prev.bottom
    anchors.left: prev.right
    margin-left: 8

  NxPanel
    id: profiles
    anchors.fill: parent
    anchors.left: prev.left
    margin-left: 8
    margin-right: 8
    padding: 8

    NxLabel
      text: Profile Settings
      text-align: center
      anchors.top: parent.top
      anchors.left: parent.left
      anchors.right: parent.right

    HorizontalSeparator
      anchors.top: prev.bottom
      anchors.left: parent.left
      anchors.right: parent.right

    NxLabel
      anchors.top: prev.bottom
      margin-top: 30
      anchors.left: parent.left
      anchors.right: parent.right
      text-align: center
      text: Profile Name:

    NxTextInput
      id: Name
      anchors.top: prev.bottom
      margin-top: 3
      anchors.left: parent.left
      anchors.right: parent.right

    NxButton
      id: ResetSettings
      anchors.bottom: parent.bottom
      anchors.horizontalCenter: parent.horizontalCenter
      text: Reset Current Profile
      text-auto-resize: true
      color: #ff4b81

HealWindow < NxWindow
  !text: tr('Self Healer')
  size: 520 360
  @onEscape: self:hide()

  NxLabel
    id: title
    anchors.left: parent.left
    anchors.top: parent.top
    margin-left: 2
    !text: tr('More important methods come first (Example: Exura gran above Exura)')
    text-align: left
    color: #a4aece

  HealerPanel
    id: healer
    anchors.top: prev.bottom
    anchors.left: parent.left

  HealBotSettingsPanel
    id: settings
    anchors.top: title.bottom
    anchors.left: parent.left
    visible: false

  NxButton
    id: closeButton
    !text: tr('Close')
    font: cipsoftFont
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    size: 45 21
    margin-right: 5

  NxButton
    id: settingsButton
    !text: tr('Settings')
    font: cipsoftFont
    anchors.left: parent.left
    anchors.bottom: parent.bottom

  HorizontalSeparator
    id: separator
    anchors.right: parent.right
    anchors.left: parent.left
    anchors.bottom: closeButton.top
    margin-bottom: 8
