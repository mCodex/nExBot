CaveBotAction < NxLabel
  background-color: alpha
  text-offset: 4 0
  focusable: true
  font: verdana-11px-rounded
  color: #f5f7ff
  height: 22

  $focus:
    background-color: #3be4d033


CaveBotPanel < Panel
  layout:
    type: verticalBox
    fit-children: true

  Panel
    id: configWidgetPlaceholder
    layout:
      type: verticalBox
      fit-children: true
    margin-top: 2
    margin-bottom: 2

  HorizontalSeparator
    margin-top: 4
    margin-bottom: 4
    
  Panel
    id: listPanel
    height: 100
    margin-top: 4

    TextList
      id: list
      anchors.fill: parent
      vertical-scrollbar: listScrollbar
      margin-right: 16
      focusable: false
      auto-focus: first
      
    VerticalScrollBar
      id: listScrollbar
      anchors.top: parent.top
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      pixels-scroll: true
      step: 16
    
  NxSwitch
    id: showEditor
    margin-top: 4
    
    $on:
      text: Hide waypoints editor
      
    $!on:
      text: Show waypoints editor

  NxSwitch
    id: showConfig
    margin-top: 4
    
    $on:
      text: Hide config
      
    $!on:
      text: Show config