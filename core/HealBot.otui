SpellSourceBoxPopupMenu < NxComboBoxPopupMenu
SpellSourceBoxPopupMenuButton < NxComboBoxPopupMenuButton
SpellSourceBox < NxComboBox
  @onSetup: |
    self:addOption("Current Mana")
    self:addOption("Current Health")
    self:addOption("Mana Percent")
    self:addOption("Health Percent")
    self:addOption("Burst Damage")

SpellConditionBoxPopupMenu < NxComboBoxPopupMenu
SpellConditionBoxPopupMenuButton < NxComboBoxPopupMenuButton
SpellConditionBox < NxComboBox
  @onSetup: |
    self:addOption("Below")
    self:addOption("Above")
    self:addOption("Equal To")

SpellEntry < NxListEntryCheckable

ItemEntry < NxListEntryCheckable
  text-offset: 58 0

  NxItem
    id: id
    anchors.left: enabled.right
    anchors.verticalCenter: parent.verticalCenter
    margin-left: 2

SpellHealing < NxPanel
  anchors.left: parent.left
  anchors.right: parent.right
  anchors.top: parent.top
  height: 188
  image-source: /images/ui/panel_flat
  image-border: 3
  padding: 7

  NxLabel
    id: title
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: parent.right
    text: Spell Healing
    text-align: center
    color: #46e6a6

  HorizontalSeparator
    anchors.top: title.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    margin-top: 4

  SpellSourceBox
    id: spellSource
    anchors.top: prev.bottom
    anchors.right: parent.right
    margin-top: 7
    width: 128
    font: verdana-11px-rounded

  NxLabel
    id: whenSpell
    anchors.left: spellList.right
    anchors.verticalCenter: prev.verticalCenter
    text: When
    margin-left: 10

  NxLabel
    id: isSpell
    anchors.left: whenSpell.left
    anchors.top: whenSpell.bottom
    text: Is
    margin-top: 11

  SpellConditionBox
    id: spellCondition
    anchors.left: spellSource.left
    anchors.top: spellSource.bottom
    margin-top: 10
    width: 80
    font: verdana-11px-rounded

  NxTextInput
    id: spellValue
    anchors.left: spellCondition.right
    anchors.top: spellCondition.top
    anchors.bottom: spellCondition.bottom
    anchors.right: spellSource.right

  NxLabel
    id: castSpell
    anchors.left: isSpell.left
    anchors.top: isSpell.bottom
    text: Cast
    margin-top: 11

  NxTextInput
    id: spellFormula
    anchors.left: spellCondition.left
    anchors.top: spellCondition.bottom
    anchors.right: spellValue.right

  NxLabel
    id: manaSpell
    anchors.left: castSpell.left
    anchors.top: castSpell.bottom
    text: Mana Cost:
    margin-top: 10

  NxTextInput
    id: manaCost
    anchors.left: spellFormula.left
    anchors.top: spellFormula.bottom
    margin-top: 2
    width: 46

  NxLabel
    id: spellHint
    anchors.left: castSpell.left
    anchors.right: spellSource.right
    anchors.top: manaSpell.bottom
    anchors.bottom: controls.top
    margin-top: 8
    margin-bottom: 4
    text: Trigger hint
    color: #a4aece
    text-wrap: true

  TextList
    id: spellList
    anchors.left: parent.left
    anchors.bottom: controls.top
    anchors.top: spellSource.top
    padding: 1
    padding-top: 2
    padding-right: 16
    width: 320
    margin-bottom: 6
    margin-left: 4
    vertical-scrollbar: spellListScrollBar

  VerticalScrollBar
    id: spellListScrollBar
    anchors.top: spellList.top
    anchors.bottom: spellList.bottom
    anchors.right: spellList.right
    step: 14
    pixels-scroll: true

  Panel
    id: controls
    anchors.left: parent.left
    margin-left: 4
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    height: 21

  NxButton
    id: addSpell
    anchors.right: controls.right
    anchors.verticalCenter: controls.verticalCenter
    text: Add Spell
    size: 74 18
    font: cipsoftFont

  NxButton
    id: MoveUp
    anchors.right: prev.left
    anchors.verticalCenter: prev.verticalCenter
    margin-right: 5
    text: Move Up
    size: 62 18
    font: cipsoftFont

  NxButton
    id: MoveDown
    anchors.right: prev.left
    anchors.verticalCenter: prev.verticalCenter
    margin-right: 5
    text: Move Down
    size: 72 18
    font: cipsoftFont

ItemHealing < NxPanel
  anchors.left: parent.left
  anchors.right: parent.right
  anchors.top: prev.bottom
  anchors.bottom: parent.bottom
  margin-top: 10
  image-source: /images/ui/panel_flat
  image-border: 3
  padding: 7

  NxLabel
    id: title
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: parent.right
    text: Item Healing
    text-align: center
    color: #ff4b81

  HorizontalSeparator
    anchors.top: title.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    margin-top: 4

  SpellSourceBox
    id: itemSource
    anchors.top: prev.bottom
    anchors.right: parent.right
    margin-top: 7
    width: 128
    font: verdana-11px-rounded

  NxLabel
    id: whenItem
    anchors.left: itemList.right
    anchors.verticalCenter: prev.verticalCenter
    text: When
    margin-left: 10

  NxLabel
    id: isItem
    anchors.left: whenItem.left
    anchors.top: whenItem.bottom
    text: Is
    margin-top: 11

  SpellConditionBox
    id: itemCondition
    anchors.left: itemSource.left
    anchors.top: itemSource.bottom
    margin-top: 10
    width: 80
    font: verdana-11px-rounded

  NxTextInput
    id: itemValue
    anchors.left: itemCondition.right
    anchors.top: itemCondition.top
    anchors.bottom: itemCondition.bottom
    width: 49

  NxLabel
    id: useItem
    anchors.left: isItem.left
    anchors.top: isItem.bottom
    text: Use
    margin-top: 11

  NxItem
    id: itemId
    anchors.left: itemCondition.left
    anchors.top: itemCondition.bottom
    margin-top: 2

  NxLabel
    id: itemHint
    anchors.left: useItem.left
    anchors.right: itemSource.right
    anchors.top: useItem.bottom
    anchors.bottom: controls.top
    margin-top: 8
    margin-bottom: 4
    text: Trigger hint
    color: #a4aece
    text-wrap: true

  TextList
    id: itemList
    anchors.left: parent.left
    anchors.bottom: controls.top
    anchors.top: itemSource.top
    padding: 1
    padding-top: 2
    padding-right: 16
    width: 320
    margin-bottom: 6
    margin-left: 4
    vertical-scrollbar: itemListScrollBar

  VerticalScrollBar
    id: itemListScrollBar
    anchors.top: itemList.top
    anchors.bottom: itemList.bottom
    anchors.right: itemList.right
    step: 14
    pixels-scroll: true

  Panel
    id: controls
    anchors.left: parent.left
    margin-left: 4
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    height: 21

  NxButton
    id: addItem
    anchors.right: controls.right
    anchors.verticalCenter: controls.verticalCenter
    text: Add Item
    size: 72 18
    font: cipsoftFont

  NxButton
    id: MoveUp
    anchors.right: prev.left
    anchors.verticalCenter: prev.verticalCenter
    margin-right: 5
    text: Move Up
    size: 62 18
    font: cipsoftFont

  NxButton
    id: MoveDown
    anchors.right: prev.left
    anchors.verticalCenter: prev.verticalCenter
    margin-right: 5
    text: Move Down
    size: 72 18
    font: cipsoftFont

HealerPanel < Panel
  anchors.left: parent.left
  anchors.right: parent.right
  anchors.top: parent.top
  anchors.bottom: parent.bottom

  SpellHealing
    id: spells
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: parent.right
    height: 188

  ItemHealing
    id: items
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    margin-top: 10

HealBotSettingsPanel < Panel
  anchors.left: parent.left
  anchors.right: parent.right
  anchors.top: parent.top
  anchors.bottom: parent.bottom
  padding-top: 8
  image-source: /images/ui/panel_flat
  image-border: 3
  padding: 8

  Panel
    id: list
    anchors.left: parent.left
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    width: 215
    padding-left: 6
    padding-right: 6
    padding-top: 6
    layout:
      type: verticalBox

    NxLabel
      id: sectionTitle
      text: Additional Settings
      color: #3be4d0
      font: verdana-11px-rounded
      height: 16
      text-align: left
      margin-bottom: 4

    HorizontalSeparator
      margin-bottom: 8

    NxCheckBox
      id: Cooldown
      text: Check spell cooldowns
      margin-top: 10

    NxCheckBox
      id: Visible
      text: Items must be visible (recommended)

    NxCheckBox
      id: Delay
      text: Don't use items when interacting

    NxCheckBox
      id: Interval
      text: Additional delay when looting corpses

    NxCheckBox
      id: Conditions
      text: Also check conditions from RL Tibia

    NxCheckBox
      id: MessageDelay
      text: Cooldown based on "Aaaah..." message

  VerticalSeparator
    anchors.top: prev.top
    anchors.bottom: prev.bottom
    anchors.left: prev.right
    margin-left: 10

  NxPanel
    id: profiles
    anchors.left: prev.right
    anchors.right: parent.right
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    margin-left: 10
    padding: 8

    NxLabel
      text: Profile Settings
      text-align: center
      anchors.top: parent.top
      anchors.left: parent.left
      anchors.right: parent.right

    HorizontalSeparator
      anchors.top: prev.bottom
      anchors.left: parent.left
      anchors.right: parent.right

    NxLabel
      anchors.top: prev.bottom
      margin-top: 30
      anchors.left: parent.left
      anchors.right: parent.right
      text-align: center
      text: Profile Name:

    NxTextInput
      id: Name
      anchors.top: prev.bottom
      margin-top: 3
      anchors.left: parent.left
      anchors.right: parent.right

    NxButton
      id: ResetSettings
      anchors.bottom: parent.bottom
      anchors.horizontalCenter: parent.horizontalCenter
      text: Reset Current Profile
      text-auto-resize: true
      color: #ff4b81

HealWindow < NxWindow
  !text: tr('Self Healer')
  size: 720 500
  minimum-size: 620 440

  NxLabel
    id: title
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.top: parent.top
    margin-top: 3
    !text: tr('More important methods come first (Example: Exura gran above Exura)')
    text-align: center
    color: #a4aece

  HealerPanel
    id: healer
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: closeButton.top
    margin-top: 6
    margin-bottom: 8

  NxButton
    id: closeButton
    !text: tr('Close')
    font: cipsoftFont
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    size: 58 21
    margin-right: 5

  HorizontalSeparator
    id: separator
    anchors.right: parent.right
    anchors.left: parent.left
    anchors.bottom: closeButton.top
    margin-bottom: 8
