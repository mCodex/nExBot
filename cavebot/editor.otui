CaveBotEditorButton < NxButton


CaveBotEditorPanel < Panel
  id: cavebotEditor
  visible: false
  layout:
    type: verticalBox
    fit-children: true
  
  Label
    id: pos
    text-align: center
    text: -
    font: verdana-11px-rounded
    color: #a4aece
    
  Panel
    id: buttons
    margin-top: 4
    layout:
      type: grid
      cell-size: 86 20
      cell-spacing: 2
      flow: true
      fit-children: true

  Label
    text: Double click on action from action list to edit it
    text-align: center
    text-auto-resize: true
    text-wrap: true
    margin-top: 4
    margin-left: 4
    margin-right: 4
    font: verdana-11px-rounded
    color: #a4aece

  NxSwitch
    id: autoRecording
    text: Auto Recording
    margin-top: 4

  NxButton
    margin-top: 4
    margin-bottom: 4
    text: Documentation
    @onClick: g_platform.openUrl("https://www.nexbot.cc/docs")
