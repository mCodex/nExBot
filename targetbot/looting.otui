TargetBotLootingPanel < Panel
  layout:
    type: verticalBox
    fit-children: true

  HorizontalSeparator
    margin-top: 8

  NxLabel
    margin-top: 8
    text: Items to loot
    text-align: center
    font: verdana-11px-rounded
    color: #3be4d0

  BotContainer
    id: items
    margin-top: 4
  
  NxSwitch
    id: everyItem
    !text: tr("Loot every item")
    margin-top: 4

  NxSwitch
    id: eatFromCorpses
    !text: tr("Eat food from corpses")
    margin-top: 4

  NxLabel
    margin-top: 8
    text: Containers for loot
    text-align: center
    font: verdana-11px-rounded
    color: #3be4d0

  BotContainer
    id: containers
    margin-top: 4
    height: 45
  
  Panel
    id: maxDangerPanel
    height: 24
    margin-top: 8
    
    NxTextInput
      id: value
      anchors.right: parent.right
      anchors.top: parent.top
      anchors.bottom: parent.bottom
      margin-right: 8
      width: 80

    NxLabel
      anchors.left: parent.left
      anchors.verticalCenter: prev.verticalCenter
      text: Max. danger:
      margin-left: 4
      font: verdana-11px-rounded
      color: #f5f7ff

  Panel
    id: minCapacityPanel
    height: 24
    margin-top: 4

    NxTextInput
      id: value
      anchors.right: parent.right
      anchors.top: parent.top
      anchors.bottom: parent.bottom
      margin-right: 8
      width: 80

    NxLabel
      anchors.left: parent.left
      anchors.verticalCenter: prev.verticalCenter
      text: Min. capacity:
      margin-left: 4
      font: verdana-11px-rounded
      color: #f5f7ff