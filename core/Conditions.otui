UturaComboBoxPopupMenu < ComboBoxPopupMenu
UturaComboBoxPopupMenuButton < ComboBoxPopupMenuButton
UturaComboBox < NxComboBox
  @onSetup: |
    self:addOption("Utura")
    self:addOption("Utura Gran")    

CureConditions < NxPanel
  id: Cure
  padding: 3
  size: 200 195

  Label
    id: poisonLabel
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 10
    margin-left: 5
    text: Poison
    color: #3be4d0
    font: verdana-11px-rounded

  Label
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 40
    text: Mana:
    font: verdana-11px-rounded

  TextEdit
    id: PoisonCost
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 3
    width: 40
    font: verdana-11px-rounded

  CheckBox
    id: CurePoison
    anchors.verticalCenter: prev.verticalCenter
    anchors.right: parent.right
    margin-right: 10

  Label
    id: curseLabel
    anchors.left: poisonLabel.left
    anchors.top: poisonLabel.bottom
    margin-top: 10
    text: Curse
    color: #3be4d0
    font: verdana-11px-rounded

  Label
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 44
    text: Mana:
    font: verdana-11px-rounded

  TextEdit
    id: CurseCost
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 3
    width: 40
    font: verdana-11px-rounded

  CheckBox
    id: CureCurse
    anchors.verticalCenter: prev.verticalCenter
    anchors.right: parent.right
    margin-right: 10

  Label
    id: bleedLabel
    anchors.left: curseLabel.left
    anchors.top: curseLabel.bottom
    margin-top: 10
    text: Bleed
    color: #3be4d0
    font: verdana-11px-rounded

  Label
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 46
    text: Mana:
    font: verdana-11px-rounded

  TextEdit
    id: BleedCost
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 3
    width: 40
    font: verdana-11px-rounded

  CheckBox
    id: CureBleed
    anchors.verticalCenter: prev.verticalCenter
    anchors.right: parent.right
    margin-right: 10

  Label
    id: burnLabel
    anchors.left: bleedLabel.left
    anchors.top: bleedLabel.bottom
    margin-top: 10
    text: Burn
    color: #3be4d0
    font: verdana-11px-rounded

  Label
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 50
    text: Mana:
    font: verdana-11px-rounded

  TextEdit
    id: BurnCost
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 3
    width: 40
    font: verdana-11px-rounded

  CheckBox
    id: CureBurn
    anchors.verticalCenter: prev.verticalCenter
    anchors.right: parent.right
    margin-right: 10

  Label
    id: electrifyLabel
    anchors.left: burnLabel.left
    anchors.top: burnLabel.bottom
    margin-top: 10
    text: Electrify
    color: #3be4d0
    font: verdana-11px-rounded

  Label
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 33
    text: Mana:
    font: verdana-11px-rounded

  TextEdit
    id: ElectrifyCost
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 3
    width: 40
    font: verdana-11px-rounded

  CheckBox
    id: CureElectrify
    anchors.verticalCenter: prev.verticalCenter
    anchors.right: parent.right
    margin-right: 10

  Label
    id: paralyseLabel
    anchors.left: electrifyLabel.left
    anchors.top: electrifyLabel.bottom
    margin-top: 10
    text: Paralyse
    color: #3be4d0
    font: verdana-11px-rounded

  Label
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 26
    text: Mana:
    font: verdana-11px-rounded

  TextEdit
    id: ParalyseCost
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 3
    width: 40
    font: verdana-11px-rounded

  CheckBox
    id: CureParalyse
    anchors.verticalCenter: prev.verticalCenter
    anchors.right: parent.right
    margin-right: 10

  Label
    anchors.left: paralyseLabel.left
    anchors.top: paralyseLabel.bottom
    margin-top: 10
    margin-left: 12
    text: Spell:
    font: verdana-11px-rounded

  TextEdit
    id: ParalyseSpell
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 10
    width: 100
    font: verdana-11px-rounded

HoldConditions < NxPanel
  id: Hold
  padding: 3
  size: 200 210

  Label
    id: hasteLabel
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 10
    margin-left: 5
    text: Haste
    color: #3be4d0
    font: verdana-11px-rounded

  Label
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 44
    text: Mana:
    font: verdana-11px-rounded

  TextEdit
    id: HasteCost
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 3
    width: 40
    font: verdana-11px-rounded

  CheckBox
    id: HoldHaste
    anchors.verticalCenter: prev.verticalCenter
    anchors.right: parent.right
    margin-right: 10

  Label
    anchors.left: hasteLabel.left
    anchors.top: hasteLabel.bottom
    margin-top: 10
    margin-left: 12
    text: Spell:
    font: verdana-11px-rounded

  TextEdit
    id: HasteSpell
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 10
    width: 100
    font: verdana-11px-rounded

  Label
    id: utanaLabel
    anchors.left: hasteLabel.left
    anchors.top: prev.bottom
    margin-top: 10
    text: Utana Vid
    color: #3be4d0
    font: verdana-11px-rounded

  Label
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 21
    text: Mana:
    font: verdana-11px-rounded

  TextEdit
    id: UtanaCost
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 3
    width: 40
    font: verdana-11px-rounded

  CheckBox
    id: HoldUtana
    anchors.verticalCenter: prev.verticalCenter
    anchors.right: parent.right
    margin-right: 10

  Label
    id: utamoLabel
    anchors.left: utanaLabel.left
    anchors.top: utanaLabel.bottom
    margin-top: 10
    text: Utamo Vita
    color: #3be4d0
    font: verdana-11px-rounded

  Label
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 12
    text: Mana:
    font: verdana-11px-rounded

  TextEdit
    id: UtamoCost
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 3
    width: 40
    font: verdana-11px-rounded

  CheckBox
    id: HoldUtamo
    anchors.verticalCenter: prev.verticalCenter
    anchors.right: parent.right
    margin-right: 10

  Label
    id: recoveryLabel
    anchors.left: utamoLabel.left
    anchors.top: utamoLabel.bottom
    margin-top: 10
    text: Recovery
    color: #3be4d0
    font: verdana-11px-rounded

  Label
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 20
    text: Mana:
    font: verdana-11px-rounded

  TextEdit
    id: UturaCost
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 3
    width: 40
    font: verdana-11px-rounded

  CheckBox
    id: HoldUtura
    anchors.verticalCenter: prev.verticalCenter
    anchors.right: parent.right
    margin-right: 10

  Label
    anchors.left: recoveryLabel.left
    anchors.top: recoveryLabel.bottom
    margin-top: 10
    margin-left: 12
    text: Spell:
    font: verdana-11px-rounded

  UturaComboBox
    id: UturaType
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-left: 10
    width: 100

  CheckBox
    id: IgnoreInPz
    anchors.left: recoveryLabel.left
    anchors.top: prev.bottom
    margin-top: 12
    font: verdana-11px-rounded

  Label
    anchors.verticalCenter: IgnoreInPz.verticalCenter
    anchors.left: prev.right
    margin-top: 3
    margin-left: 5
    text: Don't Cast in Protection Zones
    font: cipsoftFont

  CheckBox
    id: StopHaste
    anchors.horizontalCenter: IgnoreInPz.horizontalCenter
    anchors.top: IgnoreInPz.bottom
    margin-top: 8

  Label
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    margin-top: 3
    margin-left: 5
    text: Stop Haste if TargetBot Is Active
    font: cipsoftFont

ConditionsWindow < NxWindow
  !text: tr('Condition Manager')
  size: 445 280
  @onEscape: self:hide()

  CureConditions
    id: Cure
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 7

  Label
    anchors.top: parent.top
    anchors.left: parent.left
    text: Cure Conditions 
    color: #88e3dd
    margin-left: 10
    font: verdana-11px-rounded

  HoldConditions
    id: Hold
    anchors.top: parent.top
    anchors.right: parent.right
    margin-top: 7

  Label
    anchors.top: parent.top
    anchors.right: parent.right
    text: Hold Conditions 
    color: #88e3dd
    margin-right: 100
    font: verdana-11px-rounded

  HorizontalSeparator
    id: separator
    anchors.right: parent.right
    anchors.left: parent.left
    anchors.bottom: closeButton.top
    margin-bottom: 8    

  NxButtonSm
    id: closeButton
    !text: tr('Close')
    anchors.right: parent.right
    anchors.bottom: parent.bottom