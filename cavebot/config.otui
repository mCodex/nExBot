CaveBotConfigPanel < Panel
  id: cavebotEditor
  visible: false
  
  layout:
    type: verticalBox
    fit-children: true
  
  NxSeparator
    margin-top: 4

  NxLabel
    text-align: center
    text: CaveBot Config
    margin-top: 4
    font: verdana-11px-rounded
    color: #3be4d0

CaveBotConfigNumberValuePanel < Panel
  height: 24
  margin-top: 4
  
  NxTextInput
    id: value
    anchors.right: parent.right
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    margin-right: 4
    width: 50

  NxLabel
    id: title
    anchors.left: parent.left
    anchors.verticalCenter: prev.verticalCenter
    margin-left: 4
    font: verdana-11px-rounded
    color: #f5f7ff

CaveBotConfigBooleanValuePanel < Panel
  height: 24
  margin-top: 4
  
  NxSwitch
    id: value
    anchors.right: parent.right
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    margin-right: 4
    width: 50
    
    $on:
      text: On
      
    $!on:
      text: Off

  NxLabel
    id: title
    anchors.left: parent.left
    anchors.verticalCenter: prev.verticalCenter
    margin-left: 4
    font: verdana-11px-rounded
    color: #f5f7ff