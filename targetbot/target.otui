TargetBotEntry < NxLabel
  background-color: alpha
  text-offset: 4 0
  focusable: true
  font: verdana-11px-rounded
  color: #f5f7ff
  height: 22

  $focus:
    background-color: #3be4d033

TargetBotDualLabel < Panel
  height: 18
  margin-left: 4
  margin-right: 4

  NxLabel
    id: left
    anchors.top: parent.top
    anchors.left: parent.left
    text-auto-resize: true
    font: verdana-11px-rounded
    color: #f5f7ff

  NxLabel
    id: right
    anchors.top: parent.top
    anchors.right: parent.right
    text-auto-resize: true
    font: verdana-11px-rounded
    color: #a4aece

TargetBotPanel < Panel
  layout:
    type: verticalBox
    fit-children: true

  NxSeparator
    margin-top: 4
    margin-bottom: 4

  TargetBotDualLabel
    id: status
  TargetBotDualLabel
    id: target
  TargetBotDualLabel
    id: config
  TargetBotDualLabel
    id: danger

  Panel
    id: listPanel
    height: 40

    TextList
      id: list
      anchors.fill: parent
      vertical-scrollbar: listScrollbar
      margin-right: 16
      focusable: false
      auto-focus: first
      
    VerticalScrollBar
      id: listScrollbar
      anchors.top: parent.top
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      pixels-scroll: true
      step: 16
      
  NxSwitch
    id: configButton
    margin-top: 4
    @onClick: |
      self:setOn(not self:isOn())
      self:getParent().listPanel:setHeight(self:isOn() and 100 or 40)
      self:getParent().editor:setVisible(self:isOn())

    $on:
      text: Hide target editor

    $!on:
      text: Show target editor
  
  Panel
    id: editor
    visible: false
    layout:
      type: verticalBox
      fit-children: true

    Panel
      id: buttons
      height: 24
      margin-top: 4

      NxButton
        id: add
        anchors.top: parent.top
        anchors.bottom: parent.bottom
        anchors.left: parent.left
        text: Add
        width: 56
        tooltip: Add new creature target

      NxButton
        id: edit
        anchors.top: parent.top
        anchors.bottom: parent.bottom
        anchors.horizontalCenter: parent.horizontalCenter
        text: Edit
        width: 56
        tooltip: Edit selected creature target

      NxButton
        id: remove
        anchors.top: parent.top
        anchors.bottom: parent.bottom
        anchors.right: parent.right
        text: Remove
        width: 56
        tooltip: Remove selected creature target
    

